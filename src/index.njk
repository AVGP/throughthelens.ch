---
layout: layouts/base.njk
---

<!-- Hero Section -->
<section id="hero" class="hero-section">
  <div class="hero-overlay"></div>
  <div class="hero-content reveal-on-scroll">
    <div class="hero-logo-container">
      <img src="/assets/images/logo-transparent.png" alt="Through The Lens Logo" class="hero-logo">
    </div>
    <h1 class="hero-title">Through The Lens</h1>
    <p class="hero-subtitle">Modern, Elegant & Lush Portrait Photography</p>
    <div class="hero-cta-group">
      <a href="#contact" class="btn btn-primary">Book a Session</a>
      <a href="#personal" class="btn btn-secondary">Explore Portfolio</a>
    </div>
  </div>
  <div class="scroll-indicator" aria-hidden="true">
    <span class="scroll-mouse"><span class="scroll-wheel"></span></span>
    <span class="scroll-text">Scroll to Discover</span>
  </div>
</section>

<!-- Personal Portraits Section -->
<section id="personal" class="section personal-section">
  <div class="section-container">
    <div class="section-header reveal-on-scroll">
      <h2>{{ photography.offerings.personal.title }}</h2>
      <p class="section-desc">{{ photography.offerings.personal.description }}</p>
    </div>

    <div class="category-gallery reveal-on-scroll">
      {% for img in photography.offerings.personal.gallery %}
      <div class="category-gallery-item">
        <img src="{{ img }}" alt="Personal Portrait Session Preview" class="category-gallery-image">
      </div>
      {% endfor %}
    </div>

    <div class="packages-grid">
      {% for pkg in photography.offerings.personal.packages %}
      <div class="package-card {% if pkg.popular %}popular{% endif %} reveal-on-scroll">
        {% if pkg.popular %}
        <div class="popular-badge">Most Popular</div>
        {% endif %}
        <div class="card-header">
          <span class="duration">{{ pkg.duration }}</span>
          <h3>{{ pkg.name }}</h3>
          <div class="price-container">
            <span class="currency">CHF</span>
            <span class="price">{{ pkg.price }}</span>
          </div>
        </div>
        <ul class="inclusions">
          {% for item in pkg.includes %}
          <li>{{ item }}</li>
          {% endfor %}
        </ul>
        <div class="card-footer">
          <a href="#contact" class="btn btn-card" onclick="selectPackage('Personal: {{ pkg.name }}')">Select Package</a>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

