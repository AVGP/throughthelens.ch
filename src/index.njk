<!-- Contact Form Section -->
<section id="contact" class="section contact-section">
  <div class="section-container">
    <div class="section-header reveal-on-scroll">
      <span class="section-category">Booking</span>
      <h2>Begin Your Journey</h2>
      <p class="section-desc">Fill out the details below to request a session. We'll get back to you within 24 hours to finalize details and confirm your date.</p>
    </div>

    <div class="contact-form-container reveal-on-scroll">
      <form class="booking-form" id="booking-form" action="#" onsubmit="handleFormSubmit(event)">
        <div class="form-grid">
          <div class="form-group">
            <label for="client-name">Full Name</label>
            <input type="text" id="client-name" name="name" required placeholder="John Doe" autocomplete="name">
            <span class="error-msg">Please enter your name.</span>
          </div>

          <div class="form-group">
            <label for="client-email">Email Address</label>
            <input type="email" id="client-email" name="email" required placeholder="john@example.com" autocomplete="email">
            <span class="error-msg">Please enter a valid email address.</span>
          </div>

          <div class="form-group">
            <label for="client-phone">Phone Number</label>
            <input type="tel" id="client-phone" name="phone" placeholder="+41 79 123 45 67" autocomplete="tel">
          </div>

          <div class="form-group">
            <label for="session-category">Session Category</label>
            <select id="session-category" name="category" required>
              <option value="" disabled selected>Select an option</option>
              <option value="Personal">Personal Portraits</option>
              <option value="Corporate">Corporate Headshots</option>
              <option value="Creative">Creative Portraits</option>
              <option value="Custom">Custom Photo Shooting</option>
            </select>
            <span class="error-msg">Please select a shooting category.</span>
          </div>

          <div class="form-group">
            <label for="session-date">Preferred Date</label>
            <input type="date" id="session-date" name="date" required>
            <span class="error-msg">Please select a preferred date.</span>
          </div>

          <div class="form-group">
            <label for="session-details">Package details or special requests</label>
            <input type="text" id="session-details" name="details" placeholder="e.g. Lifestyle Session Package">
          </div>
        </div>

        <div class="form-group textarea-group">
          <label for="client-message">Tell us about your project</label>
          <textarea id="client-message" name="message" rows="5" required placeholder="Describe the shoot location, details, style preferences..."></textarea>
          <span class="error-msg">Please describe your session requirements.</span>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-submit" id="submit-btn">Send Booking Request</button>
        </div>
        
        <div class="form-response-success" id="form-success-msg" aria-hidden="true" style="display: none;">
          <h4>Booking Request Sent Successfully!</h4>
          <p>Thank you! We have received your booking inquiry and will review it. A photographer will be in touch with you shortly.</p>
        </div>
      </form>
    </div>
  </div>
</section>

<!-- Script for interactivity -->
<script>
  // Pre-fill the booking details field when clicking package CTA
  function selectPackage(packageName) {
    const detailsInput = document.getElementById('session-details');
    const categorySelect = document.getElementById('session-category');
    
    if (detailsInput) {
      detailsInput.value = packageName;
    }
    
    if (categorySelect) {
      if (packageName.startsWith('Personal:')) {
        categorySelect.value = 'Personal';
      } else if (packageName.startsWith('Corporate:')) {
        categorySelect.value = 'Corporate';
      } else if (packageName.startsWith('Creative:')) {
        categorySelect.value = 'Creative';
      }
    }
  }

  // Handle Contact Form Submission
  function handleFormSubmit(event) {
    event.preventDefault();
    const form = document.getElementById('booking-form');
    const successMsg = document.getElementById('form-success-msg');
    const submitBtn = document.getElementById('submit-btn');

    if (form.checkValidity()) {
      // Simulation:
      submitBtn.disabled = true;
      submitBtn.innerText = 'Sending...';

      setTimeout(() => {
        form.reset();
        submitBtn.style.display = 'none';
        successMsg.style.display = 'block';
        successMsg.setAttribute('aria-hidden', 'false');
        
        successMsg.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }, 1200);
    }
  }

  // Set min date for date selector to today
  const dateInput = document.getElementById('session-date');
  if (dateInput) {
    const today = new Date().toISOString().split('T')[0];
    dateInput.min = today;
  }
</script>
